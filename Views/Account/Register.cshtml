@model RegisterViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Register";
}

<div class="auth-card">
    <div class="auth-logo">
        <div class="logo-icon"><i class="bi bi-person-plus-fill"></i></div>
        <h2>Create Account</h2>
        <p>Register a new account</p>
    </div>

    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

        <div class="mb-3">
            <label asp-for="StaffName" class="form-label"></label>
            <input asp-for="StaffName" class="form-control" placeholder="Full name" />
            <span asp-validation-for="StaffName" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Username" class="form-label"></label>
            <input asp-for="Username" class="form-control" placeholder="Email address" />
            <span asp-validation-for="Username" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <div class="password-wrapper">
                <input asp-for="Password" class="form-control" placeholder="Create password" />
                <button type="button" class="toggle-pwd"><i class="bi bi-eye"></i></button>
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <div class="password-wrapper">
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm password" />
                <button type="button" class="toggle-pwd"><i class="bi bi-eye"></i></button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Register</button>
    </form>

    <div class="auth-footer">
        Already have an account? <a asp-action="Login">Sign in</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
