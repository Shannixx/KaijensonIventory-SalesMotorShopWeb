@model Product
@{ ViewData["Title"] = "Delete Product"; }

<div class="page-header"><div><h1>Delete Product</h1><p>Are you sure you want to delete this product?</p></div></div>

<div class="card border-danger">
    <div class="card-body">
        <div class="row g-4">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <div class="col-md-4 text-center">
                    <img src="@Model.ImagePath" alt="@Model.ProductName" class="img-fluid rounded border" style="max-height:200px;" />
                </div>
            }
            <div class="@(string.IsNullOrEmpty(Model.ImagePath) ? "col-md-12" : "col-md-8")">
                <table class="table table-borderless mb-0">
                    <tr><th style="width:180px;">Product ID</th><td>@Model.ProductId</td></tr>
                    <tr><th>Name</th><td>@Model.ProductName</td></tr>
                    <tr><th>Description</th><td>@(Model.Description ?? "-")</td></tr>
                    <tr><th>Category</th><td>@Model.Category?.CategoryName</td></tr>
                    <tr><th>Supplier</th><td>@Model.Supplier?.CompanyName</td></tr>
                    <tr><th>Price</th><td>@Model.Price.ToString("N2")</td></tr>
                    <tr><th>Stock</th><td>@Model.QuantityOnHand (@Model.StockStatus)</td></tr>
                </table>
            </div>
        </div>
    </div>
    <div class="card-footer bg-transparent d-flex gap-2 justify-content-end">
        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.ProductId" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</div>
