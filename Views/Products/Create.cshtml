@model Product
@{ ViewData["Title"] = "Create Product"; }

<div class="page-header"><div><h1>Create Product</h1><p>Add a new product to inventory.</p></div></div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" enctype="multipart/form-data">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="ProductName" class="form-label"></label>
                    <input asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Brand" class="form-label"></label>
                    <input asp-for="Brand" class="form-control" list="brandList" placeholder="e.g. Honda" />
                    <datalist id="brandList">
                        <option value="Honda"></option>
                        <option value="Yamaha"></option>
                        <option value="Suzuki"></option>
                        <option value="Kawasaki"></option>
                        <option value="Kymco"></option>
                        <option value="SYM"></option>
                        <option value="Rusi"></option>
                        <option value="Motorstar"></option>
                        <option value="Skygo"></option>
                        <option value="Bajaj"></option>
                        <option value="CFMoto"></option>
                        <option value="Benelli"></option>
                        <option value="TVS"></option>
                        <option value="BMW"></option>
                        <option value="KTM"></option>
                        <option value="Harley-Davidson"></option>
                        <option value="Ducati"></option>
                    </datalist>
                    <span asp-validation-for="Brand" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="PartNumber" class="form-label"></label>
                    <input asp-for="PartNumber" class="form-control" placeholder="e.g. 15410-KPP-901" />
                    <span asp-validation-for="PartNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="PartType" class="form-label"></label>
                    <select asp-for="PartType" class="form-select">
                        <option value="">Select</option>
                        <option value="Engine Parts">Engine Parts</option>
                        <option value="Brake Parts">Brake Parts</option>
                        <option value="Electrical Parts">Electrical Parts</option>
                        <option value="Oil">Oil</option>
                        <option value="Filters">Filters</option>
                        <option value="Tires">Tires</option>
                        <option value="Bearings">Bearings</option>
                        <option value="Chain Set">Chain Set</option>
                        <option value="Suspension">Suspension</option>
                        <option value="Accessories">Accessories</option>
                        <option value="Body Parts">Body Parts</option>
                        <option value="Gaskets">Gaskets</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="ModelCompatibility" class="form-label"></label>
                    <input asp-for="ModelCompatibility" class="form-control" placeholder="e.g. Click 125, NMAX, Raider 150" />
                    <span asp-validation-for="ModelCompatibility" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="SupplierId" class="form-label"></label>
                    <select asp-for="SupplierId" class="form-select" asp-items="ViewBag.Suppliers">
                        <option value="">-- Select Supplier --</option>
                    </select>
                    <span asp-validation-for="SupplierId" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="QuantityOnHand" class="form-label"></label>
                    <input asp-for="QuantityOnHand" class="form-control" />
                    <span asp-validation-for="QuantityOnHand" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="LeadTimeDays" class="form-label"></label>
                    <input asp-for="LeadTimeDays" class="form-control" />
                    <span asp-validation-for="LeadTimeDays" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="ReorderLevel" class="form-label">Reorder Level</label>
                    <input asp-for="ReorderLevel" class="form-control" id="ReorderLevel" readonly="@(Model.UseAutoReorder ? "readonly" : null)" />
                    <span asp-validation-for="ReorderLevel" class="text-danger small"></span>
                    <small id="reorderNote" class="text-muted" style="display:@(Model.UseAutoReorder ? "inline" : "none")">Computed: Avg Daily Sales &times; Lead Time</small>
                </div>
                <div class="col-md-2">
                    <label asp-for="AverageCost" class="form-label"></label>
                    <input asp-for="AverageCost" class="form-control" step="0.01" />
                    <span asp-validation-for="AverageCost" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="UseAutoReorder" class="form-check-input" id="UseAutoReorder" />
                        <label asp-for="UseAutoReorder" class="form-check-label"></label>
                    </div>
                </div>
                <div class="col-md-6">
                    <label asp-for="ImagePath" class="form-label">Product Image</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('UseAutoReorder').addEventListener('change', function() {
            var field = document.getElementById('ReorderLevel');
            var note = document.getElementById('reorderNote');
            if (this.checked) {
                field.readOnly = true;
                field.value = '1';
                note.style.display = 'inline';
            } else {
                field.readOnly = false;
                note.style.display = 'none';
            }
        });
    </script>
}
