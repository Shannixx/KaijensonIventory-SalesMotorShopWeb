@model Product
@{
    ViewData["Title"] = "Product Details";
    string badgeClass = Model.StockStatus switch
    {
        "Out of Stock" => "bg-danger",
        "Low Stock" => "bg-warning text-dark",
        "Critical" => "bg-danger",
        "Available" => "bg-success",
        _ => "bg-success"
    };
    string statusLabel = Model.StockStatus switch
    {
        "Out of Stock" => "Out of Stock",
        "Low Stock" => "Low Stock",
        "Available" when Model.QuantityOnHand > Model.ReorderLevel * 2 => "Healthy",
        "Available" => "Low Stock",
        _ => Model.StockStatus
    };
    if (Model.QuantityOnHand <= 0) { statusLabel = "Out of Stock"; badgeClass = "bg-danger"; }
    else if (Model.QuantityOnHand <= Model.ReorderLevel / 2) { statusLabel = "Critical"; badgeClass = "bg-danger"; }
    else if (Model.QuantityOnHand <= Model.ReorderLevel) { statusLabel = "Low Stock"; badgeClass = "bg-warning text-dark"; }
    else { statusLabel = "Healthy"; badgeClass = "bg-success"; }
}

<div class="page-header">
    <div>
        <h1>@Model.ProductName</h1>
        <p>Product details and inventory information.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a>
        @if (Model.UseAutoReorder)
        {
            <form asp-action="Recalculate" asp-route-id="@Model.ProductId" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-info"><i class="bi bi-arrow-repeat"></i> Recalculate</button>
            </form>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon primary"><i class="bi bi-box"></i></div>
            <div class="metric-info">
                <p class="metric-label">Current Stock</p>
                <h3 class="metric-value">@Model.QuantityOnHand</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon warning"><i class="bi bi-arrow-repeat"></i></div>
            <div class="metric-info">
                <p class="metric-label">Reorder Level</p>
                <h3 class="metric-value">@Model.ReorderLevel</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon info"><i class="bi bi-clock"></i></div>
            <div class="metric-info">
                <p class="metric-label">Lead Time</p>
                <h3 class="metric-value">@Model.LeadTimeDays days</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon success"><i class="bi bi-currency-dollar"></i></div>
            <div class="metric-info">
                <p class="metric-label">Inventory Value</p>
                <h3 class="metric-value" data-prefix="₱">₱@ViewBag.InventoryValue?.ToString("N2")</h3>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="row g-4">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <div class="col-md-4 text-center">
                    <img src="@Model.ImagePath" alt="@Model.ProductName" class="img-fluid rounded border" style="max-height:250px;" />
                </div>
            }
            <div class="@(string.IsNullOrEmpty(Model.ImagePath) ? "col-md-12" : "col-md-8")">
                <table class="table table-borderless mb-0">
                    <tr><th style="width:200px;">Product ID</th><td>@Model.ProductId</td></tr>
                    <tr><th>Name</th><td>@Model.ProductName</td></tr>
                    <tr><th>Brand</th><td>@(Model.Brand ?? "-")</td></tr>
                    <tr><th>Part Number</th><td>@(Model.PartNumber ?? "-")</td></tr>
                    <tr><th>Part Type</th><td>@(Model.PartType ?? "-")</td></tr>
                    <tr><th>Model Compatibility</th><td>@(Model.ModelCompatibility ?? "-")</td></tr>
                    <tr><th>Description</th><td>@(Model.Description ?? "-")</td></tr>
                    <tr><th>Category</th><td>@Model.Category?.CategoryName</td></tr>
                    <tr><th>Supplier</th><td><a asp-controller="Suppliers" asp-action="Details" asp-route-id="@Model.SupplierId">@Model.Supplier?.CompanyName</a> &middot; @Model.Supplier?.ContactNumber</td></tr>
                    <tr><th>Price</th><td class="fw-semibold fs-5">@Model.Price.ToString("N2")</td></tr>
                    <tr><th>Average Cost</th><td>@Model.AverageCost.ToString("N2")</td></tr>
                    <tr><th>Current Stock</th><td>@Model.QuantityOnHand <span class="badge @badgeClass ms-2">@statusLabel</span></td></tr>
                    <tr><th>Reorder Level</th><td>
                        @Model.ReorderLevel
                        @if (Model.UseAutoReorder) { <span class="badge bg-info ms-1">Auto</span> }
                    </td></tr>
                    <tr><th>Lead Time (Days)</th><td>@Model.LeadTimeDays</td></tr>
                    <tr><th>Avg Daily Sales (90d)</th><td>@(ViewBag.AverageDailySales?.ToString("N2") ?? "0.00")</td></tr>
                    <tr><th>Last Sale Date</th><td>@(ViewBag.LastSaleDate?.ToString("MMM dd, yyyy") ?? "-")</td></tr>
                    <tr><th>Last Stock In Date</th><td>@(ViewBag.LastStockInDate?.ToString("MMM dd, yyyy") ?? "-")</td></tr>
                    <tr><th>Last Recalculated</th><td>@(Model.LastRecalcDate?.ToString("MMM dd, yyyy") ?? "-")</td></tr>
                    <tr><th>Created At</th><td>@Model.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</td></tr>
                </table>
            </div>
        </div>
    </div>
</div>
