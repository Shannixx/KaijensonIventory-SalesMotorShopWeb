@model Mechanic
@{ ViewData["Title"] = "Delete Mechanic"; }
<div class="page-header">
    <div>
        <h1>Delete Mechanic</h1>
        <p>Are you sure you want to delete this mechanic?</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Back to List</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card">
    <div class="card-body">
        <dl class="row mb-4">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.MechanicId</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.MechanicName</dd>

            <dt class="col-sm-3">Specialization</dt>
            <dd class="col-sm-9">@Model.Specialization</dd>

            <dt class="col-sm-3">Contact Number</dt>
            <dd class="col-sm-9">@Model.ContactNumber</dd>

            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@Model.Address</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="MechanicId" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
            <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
        </form>
    </div>
</div>
