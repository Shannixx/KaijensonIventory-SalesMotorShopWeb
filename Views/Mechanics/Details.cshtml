@model Mechanic
@{ ViewData["Title"] = "Mechanic Details"; }
<div class="page-header">
    <div>
        <h1>Mechanic Details</h1>
        <p>View mechanic information.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.MechanicId" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Back to List</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.MechanicId</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.MechanicName</dd>

            <dt class="col-sm-3">Specialization</dt>
            <dd class="col-sm-9">@Model.Specialization</dd>

            <dt class="col-sm-3">Contact Number</dt>
            <dd class="col-sm-9">@Model.ContactNumber</dd>

            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@Model.Address</dd>
        </dl>
    </div>
</div>
