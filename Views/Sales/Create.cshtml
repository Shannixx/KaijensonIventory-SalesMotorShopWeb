@model SalesTransaction
@{ ViewData["Title"] = "New Sale"; }

<div class="page-header">
    <div>
        <h1>New Sale</h1>
        <p>@ViewBag.InvoiceNumber</p>
    </div>
</div>

<form asp-action="Create" method="post" id="saleForm">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Products</span>
                    <input type="text" class="form-control form-control-sm" style="width:200px;" placeholder="Search product..." id="productSearch" />
                </div>
                <div class="card-body">
                    @{
                        var products = (IEnumerable<Product>)ViewBag.ProductsList;
                    }
                    <div class="row g-2" id="productGrid">
                        @foreach (var p in products)
                        {
                            <div class="col-md-4 col-sm-6 product-card" data-name="@p.ProductName.ToLower()">
                                <div class="card h-100 border cursor-pointer product-item" data-id="@p.ProductId" data-name="@p.ProductName" data-price="@p.Price.ToString("F2")" style="cursor:pointer; transition:all 0.15s;">
                                    <div class="card-body text-center py-2">
                                        @if (!string.IsNullOrEmpty(p.ImagePath))
                                        {
                                            <img src="@p.ImagePath" alt="" style="width:50px;height:50px;object-fit:cover;border-radius:6px;margin-bottom:4px;" onerror="this.style.display='none'" />
                                        }
                                        <div class="fw-semibold small mb-1">@p.Brand - @p.ProductName</div>
                                        <div class="text-primary fw-bold">@p.Price.ToString("N2")</div>
                                        <div class="small text-muted">Stock: @p.QuantityOnHand</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card">
                <div class="card-header d-flex justify-content-between">
                    <span>Shopping Cart</span>
                    <span class="text-muted" id="cartCount">0 item(s)</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-container">
                        <table class="table mb-0" id="cartTable">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th style="width:90px;">Qty</th>
                                    <th style="width:80px;">Price</th>
                                    <th style="width:80px;">Subtotal</th>
                                    <th style="width:30px;"></th>
                                </tr>
                            </thead>
                            <tbody id="cartBody">
                                <tr id="cartEmpty"><td colspan="5" class="text-center py-4 text-muted">Cart is empty.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-body border-top">
                    <div class="d-flex justify-content-between mb-1"><span>Total:</span><span class="fw-bold" id="cartTotal">0.00</span></div>
                    <hr />
                    <div class="mb-2">
                        <label class="form-label small">Customer</label>
                        <div class="d-flex gap-3 mb-2">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="customerType" id="customerWalkin" value="walkin" checked>
                                <label class="form-check-label small" for="customerWalkin">Walk-in Customer</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="customerType" id="customerExisting" value="existing">
                                <label class="form-check-label small" for="customerExisting">Existing Customer</label>
                            </div>
                        </div>
                        <div id="walkinCustomerPanel">
                            <div class="mb-1">
                                <input type="text" name="walkinName" id="walkinName" class="form-control" placeholder="Customer Name *" required />
                            </div>
                            <div class="mb-1">
                                <input type="text" name="walkinContact" id="walkinContact" class="form-control" placeholder="Contact Number (optional)" />
                            </div>
                        </div>
                        <div id="existingCustomerPanel" style="display:none;">
                            <div class="input-group input-group-sm mb-1">
                                <input type="text" class="form-control" id="customerSearch" placeholder="Search customer..." autocomplete="off">
                                <button class="btn btn-outline-primary" type="button" id="quickAddBtn"><i class="bi bi-person-plus"></i> Quick Add</button>
                            </div>
                            <div id="customerSearchResults" class="list-group mb-2" style="max-height:150px;overflow-y:auto;display:none;"></div>
                            <div id="selectedCustomerDisplay" class="small text-muted" style="display:none;">
                                <i class="bi bi-person-check"></i> <span id="selectedCustomerName"></span>
                            </div>
                            <input type="hidden" name="selectedCustomerId" id="selectedCustomerId" value="" />
                        </div>
                        <input type="hidden" asp-for="CustomerName" id="customerNameHidden" value="Walk-in Customer" />
                        <span asp-validation-for="CustomerName" class="text-danger small"></span>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Amount Paid</label>
                        <input asp-for="AmountPaid" class="form-control" id="amountPaid" step="0.01" min="0" required />
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Change:</span>
                        <span class="fw-bold" id="changeDisplay">0.00</span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100" id="checkoutBtn"><i class="bi bi-check-lg"></i> Complete Sale</button>
                </div>
            </div>
        </div>
    </div>

    <div id="itemsContainer"></div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let cart = [];

        function renderCart() {
            const tbody = document.getElementById('cartBody');
            const empty = document.getElementById('cartEmpty');
            let html = '';
            let total = 0;
            let count = 0;

            cart.forEach((item, index) => {
                const sub = item.price * item.quantity;
                total += sub;
                count += item.quantity;
                html += `<tr>
                    <td>${item.name}</td>
                    <td>
                        <div class="input-group input-group-sm" style="max-width:100px;">
                            <button class="btn btn-outline-secondary" type="button" onclick="changeQty(${index}, -1)">−</button>
                            <input type="number" class="form-control text-center" value="${item.quantity}" min="1" onchange="changeQtyTo(${index}, this.value)" />
                            <button class="btn btn-outline-secondary" type="button" onclick="changeQty(${index}, 1)">+</button>
                        </div>
                    </td>
                    <td>${item.price.toFixed(2)}</td>
                    <td>${sub.toFixed(2)}</td>
                    <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeItem(${index})">&times;</button></td>
                </tr>`;
            });

            if (cart.length === 0) {
                tbody.innerHTML = '<tr id="cartEmpty"><td colspan="5" class="text-center py-4 text-muted">Cart is empty.</td></tr>';
            } else {
                tbody.innerHTML = html;
            }

            document.getElementById('cartTotal').textContent = total.toFixed(2);
            document.getElementById('cartCount').textContent = count + ' item(s)';
            computeChange();
        }

        function computeChange() {
            const total = parseFloat(document.getElementById('cartTotal').textContent) || 0;
            const paid = parseFloat(document.getElementById('amountPaid').value) || 0;
            document.getElementById('changeDisplay').textContent = (paid - total).toFixed(2);
        }

        document.getElementById('amountPaid').addEventListener('input', computeChange);

        function addToCart(id, name, price) {
            const existing = cart.findIndex(i => i.productId === id);
            if (existing >= 0) {
                cart[existing].quantity++;
            } else {
                cart.push({ productId: id, name, price, quantity: 1 });
            }
            renderCart();
        }

        function changeQty(index, delta) {
            if (cart[index]) {
                cart[index].quantity = Math.max(1, cart[index].quantity + delta);
                renderCart();
            }
        }

        function changeQtyTo(index, val) {
            const qty = parseInt(val) || 1;
            if (cart[index]) {
                cart[index].quantity = Math.max(1, qty);
                renderCart();
            }
        }

        function removeItem(index) {
            cart.splice(index, 1);
            renderCart();
        }

        // --- Customer selection ---

        function selectCustomer(id, name) {
            document.getElementById('selectedCustomerId').value = id;
            document.getElementById('selectedCustomerName').textContent = name;
            document.getElementById('selectedCustomerDisplay').style.display = 'block';
            document.getElementById('customerNameHidden').value = name;
            document.getElementById('customerSearchResults').style.display = 'none';
            document.getElementById('customerSearch').value = name;
            document.getElementById('customerSearch').disabled = true;
        }

        function clearCustomerSelection() {
            document.getElementById('selectedCustomerId').value = '';
            document.getElementById('selectedCustomerDisplay').style.display = 'none';
            document.getElementById('customerSearch').value = '';
            document.getElementById('customerSearch').disabled = false;
            document.getElementById('customerSearchResults').style.display = 'none';
        }

        // Radio toggle
        document.querySelectorAll('input[name="customerType"]').forEach(el => {
            el.addEventListener('change', function () {
                const existingPanel = document.getElementById('existingCustomerPanel');
                const walkinPanel = document.getElementById('walkinCustomerPanel');
                if (this.value === 'walkin') {
                    existingPanel.style.display = 'none';
                    walkinPanel.style.display = 'block';
                    clearCustomerSelection();
                } else {
                    existingPanel.style.display = 'block';
                    walkinPanel.style.display = 'none';
                }
            });
        });

        // Customer search with debounce
        let searchTimeout;
        document.getElementById('customerSearch').addEventListener('input', function () {
            clearTimeout(searchTimeout);
            const term = this.value.trim();
            if (term.length < 1) {
                document.getElementById('customerSearchResults').style.display = 'none';
                return;
            }
            searchTimeout = setTimeout(() => {
                fetch(`/Sales/GetCustomersJson?term=${encodeURIComponent(term)}`)
                    .then(r => r.json())
                    .then(data => {
                        const results = document.getElementById('customerSearchResults');
                        results.innerHTML = '';
                        if (data.length === 0) {
                            results.innerHTML = '<div class="list-group-item text-muted small">No customers found.</div>';
                        } else {
                            data.forEach(c => {
                                const item = document.createElement('a');
                                item.href = '#';
                                item.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center py-1';
                                item.innerHTML = `<span class="small fw-medium">${c.name}</span><small class="text-muted">${c.contact}</small>`;
                                item.addEventListener('click', function (e) {
                                    e.preventDefault();
                                    selectCustomer(c.id, c.name);
                                });
                                results.appendChild(item);
                            });
                        }
                        results.style.display = 'block';
                    });
            }, 300);
        });

        // Close search results when clicking outside
        document.addEventListener('click', function (e) {
            const panel = document.getElementById('existingCustomerPanel');
            if (panel.style.display !== 'none' && !panel.contains(e.target)) {
                setTimeout(() => {
                    document.getElementById('customerSearchResults').style.display = 'none';
                }, 200);
            }
        });

        // Quick Add modal
        document.getElementById('quickAddBtn').addEventListener('click', function () {
            if (!document.getElementById('quickAddModal')) {
                const modalHtml = `
                    <div class="modal fade" id="quickAddModal" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Quick Add Customer</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-2">
                                        <label class="form-label small">Customer Name <span class="text-danger">*</span></label>
                                        <input type="text" id="quickAddName" class="form-control" required />
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label small">Contact Number</label>
                                        <input type="text" id="quickAddContact" class="form-control" placeholder="Optional" />
                                    </div>
                                    <div id="quickAddError" class="text-danger small" style="display:none;"></div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="button" class="btn btn-primary" id="quickAddSave"><i class="bi bi-check-lg"></i> Add & Select</button>
                                </div>
                            </div>
                        </div>
                    </div>`;
                document.body.insertAdjacentHTML('beforeend', modalHtml);
                // Wire save only once
                document.getElementById('quickAddSave').addEventListener('click', function () {
                    const name = document.getElementById('quickAddName').value.trim();
                    const contact = document.getElementById('quickAddContact').value.trim();
                    if (!name) {
                        document.getElementById('quickAddError').textContent = 'Customer name is required.';
                        document.getElementById('quickAddError').style.display = 'block';
                        return;
                    }
                    // Set form fields for server-side quick add
                    document.querySelector('input[name="customerType"][value="walkin"]').checked = false;
                    document.querySelector('input[name="customerType"][value="existing"]').checked = false;
                    document.querySelector('#customerNameHidden').value = name;
                    // Add hidden fields for quick add data
                    let qaType = document.querySelector('input[name="customerType"][value="quickadd"]');
                    if (!qaType) {
                        qaType = document.createElement('input');
                        qaType.type = 'hidden';
                        qaType.name = 'customerType';
                        qaType.value = 'quickadd';
                        document.getElementById('saleForm').appendChild(qaType);
                    }
                    qaType.value = 'quickadd';
                    let qaName = document.querySelector('input[name="quickAddName"]');
                    if (!qaName) {
                        qaName = document.createElement('input');
                        qaName.type = 'hidden';
                        qaName.name = 'quickAddName';
                        document.getElementById('saleForm').appendChild(qaName);
                    }
                    qaName.value = name;
                    let qaContact = document.querySelector('input[name="quickAddContact"]');
                    if (!qaContact) {
                        qaContact = document.createElement('input');
                        qaContact.type = 'hidden';
                        qaContact.name = 'quickAddContact';
                        document.getElementById('saleForm').appendChild(qaContact);
                    }
                    qaContact.value = contact;
                    // Update display
                    document.getElementById('selectedCustomerId').value = '';
                    document.getElementById('selectedCustomerName').textContent = name;
                    document.getElementById('selectedCustomerDisplay').style.display = 'block';
                    document.getElementById('existingCustomerPanel').style.display = 'block';
                    document.getElementById('customerSearch').value = name;
                    document.getElementById('customerSearch').disabled = true;
                    document.getElementById('customerSearchResults').style.display = 'none';

                    bootstrap.Modal.getInstance(document.getElementById('quickAddModal')).hide();
                });
            }
            const modal = new bootstrap.Modal(document.getElementById('quickAddModal'));
            document.getElementById('quickAddName').value = '';
            document.getElementById('quickAddContact').value = '';
            document.getElementById('quickAddError').style.display = 'none';
            modal.show();
        });

        // Product click handlers
        document.querySelectorAll('.product-item').forEach(el => {
            el.addEventListener('click', function () {
                const id = parseInt(this.dataset.id);
                const name = this.dataset.name;
                const price = parseFloat(this.dataset.price);
                addToCart(id, name, price);
                this.style.borderColor = '#FD7E14';
                this.style.boxShadow = '0 0 0 2px rgba(253,126,20,0.2)';
                setTimeout(() => {
                    this.style.borderColor = '';
                    this.style.boxShadow = '';
                }, 500);
            });
        });

        document.getElementById('productSearch').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('.product-card').forEach(el => {
                el.style.display = el.dataset.name.includes(q) ? '' : 'none';
            });
        });

        document.getElementById('saleForm').addEventListener('submit', function (e) {
            if (cart.length === 0) {
                e.preventDefault();
                alert('Please add at least one item to the cart.');
                return;
            }
            const customerType = document.querySelector('input[name="customerType"]:checked');
            if (customerType && customerType.value === 'walkin') {
                const name = document.getElementById('walkinName').value.trim();
                if (!name) {
                    e.preventDefault();
                    alert('Please enter a customer name.');
                    return;
                }
                document.getElementById('customerNameHidden').value = name;
            }
            const container = document.getElementById('itemsContainer');
            container.innerHTML = '';
            cart.forEach((item, index) => {
                container.innerHTML += `<input type="hidden" name="items[${index}].ProductId" value="${item.productId}" />`;
                container.innerHTML += `<input type="hidden" name="items[${index}].Quantity" value="${item.quantity}" />`;
            });
        });
    </script>
    <style>
        .product-item:hover { border-color: #FD7E14 !important; box-shadow: 0 0 0 2px rgba(253,126,20,0.15); }
        .product-item:active { transform: scale(0.97); }
        .cursor-pointer { cursor: pointer; }
    </style>
}
