@model KaijensonIventory_SalesMotorShopWeb.Models.Category
@{ ViewData["Title"] = "Category Details"; }

<div class="page-header">
    <div>
        <h1>Category Details</h1>
        <p>View category information.</p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.CategoryId)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.CategoryId)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.CategoryName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.CategoryName)</dd>
        </dl>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
        </div>
    </div>
</div>
