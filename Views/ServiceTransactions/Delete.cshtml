@model ServiceTransaction
@{ ViewData["Title"] = "Delete Service Transaction"; }

<div class="page-header">
    <div>
        <h1>Delete Service Transaction</h1>
        <p>Are you sure you want to delete this transaction? Stock for parts used will be restored.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="card border-danger">
    <div class="card-body">
        <dl class="row mb-4">
            <dt class="col-sm-3">Transaction ID</dt>
            <dd class="col-sm-9">@Model.ServiceTxnId</dd>

            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">@Model.CustomerName</dd>

            <dt class="col-sm-3">Vehicle</dt>
            <dd class="col-sm-9">@Model.Make @Model.Model@(Model.Year.HasValue ? $" ({Model.Year})" : "")</dd>

            <dt class="col-sm-3">Plate Number</dt>
            <dd class="col-sm-9">@(Model.PlateNumber ?? "-")</dd>

            <dt class="col-sm-3">Service Fee</dt>
            <dd class="col-sm-9">@Model.ServiceFee.ToString("N2")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Status == "Pending") { <span class="badge bg-warning text-dark">Pending</span> }
                else if (Model.Status == "In Progress") { <span class="badge bg-info">In Progress</span> }
                else { <span class="badge bg-success">Completed</span> }
            </dd>

            <dt class="col-sm-3">Mechanic</dt>
            <dd class="col-sm-9">@Model.Mechanic?.MechanicName</dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.Date.ToString("MMM dd, yyyy")</dd>
        </dl>

        @if (Model.PartsUsed.Any())
        {
            <h6 class="text-muted mb-2">Parts Used (will be restored)</h6>
            <table class="table table-sm mb-4">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var part in Model.PartsUsed)
                    {
                        <tr>
                            <td>@part.Product?.ProductName</td>
                            <td>@part.Quantity</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="ServiceTxnId" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
