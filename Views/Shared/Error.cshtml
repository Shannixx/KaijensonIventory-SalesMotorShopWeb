@{
    ViewData["Title"] = "Error";
    Layout = "_AuthLayout";
}

<div class="auth-card" style="text-align:center;">
    <div class="auth-logo">
        <div class="logo-icon"><i class="bi bi-exclamation-triangle"></i></div>
        <h2>Something went wrong</h2>
        <p>An unexpected error occurred. Please try again or contact support.</p>
    </div>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary w-100"><i class="bi bi-house"></i> Go to Dashboard</a>
</div>
