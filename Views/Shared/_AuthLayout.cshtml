<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kaijenson Motor Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KaijensonIventory_SalesMotorShopWeb.styles.css" asp-append-version="true" />
    <style>
        body.auth-page {
            background: #1E2640;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            font-family: 'Inter', sans-serif;
            position: relative;
            overflow-x: hidden;
        }

        body.auth-page::before {
            content: '';
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(ellipse at 20% 50%, rgba(255,127,17,0.06) 0%, transparent 50%),
                        radial-gradient(ellipse at 80% 50%, rgba(255,127,17,0.04) 0%, transparent 50%);
            pointer-events: none;
        }

        .auth-card {
            background: #fff;
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            position: relative;
            animation: authFadeIn 0.5s ease-out;
            transition: box-shadow 0.3s ease, transform 0.3s ease;
        }

        .auth-card:hover {
            box-shadow: 0 24px 72px rgba(0,0,0,0.35);
        }

        @@keyframes authFadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 28px;
        }

        .auth-logo .logo-icon {
            width: 60px;
            height: 60px;
            background: #FF7F11;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: #fff;
            margin-bottom: 14px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .auth-logo .logo-icon:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 24px rgba(255,127,17,0.3);
        }

        .auth-logo h2 {
            font-size: 18px;
            font-weight: 700;
            margin: 0;
            color: #1F2937;
        }

        .auth-logo p {
            font-size: 13px;
            color: #9CA3AF;
            margin: 2px 0 0;
        }

        .auth-card .form-label {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #6B7280;
            margin-bottom: 6px;
            display: block;
        }

        .input-icon-group {
            position: relative;
        }

        .input-icon-group .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9CA3AF;
            font-size: 16px;
            pointer-events: none;
            transition: color 0.2s ease;
            z-index: 2;
        }

        .input-icon-group:focus-within .input-icon {
            color: #FF7F11;
        }

        .auth-card .form-control {
            padding: 12px 14px 12px 42px;
            font-size: 14px;
            border: 1.5px solid #E5E7EB;
            border-radius: 10px;
            transition: all 0.25s ease;
            background: #FAFAFA;
        }

        .auth-card .form-control:focus {
            border-color: #FF7F11;
            box-shadow: 0 0 0 4px rgba(255,127,17,0.1);
            background: #fff;
            outline: none;
        }

        .auth-card .form-control::placeholder {
            color: #B0B7C3;
            font-size: 13px;
        }

        .auth-card .form-control.is-invalid {
            border-color: #EF4444;
            box-shadow: 0 0 0 3px rgba(239,68,68,0.08);
        }

        .password-wrapper {
            position: relative;
        }

        .password-wrapper .form-control {
            padding-right: 42px;
        }

        .password-wrapper .toggle-pwd {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #9CA3AF;
            cursor: pointer;
            padding: 6px;
            font-size: 16px;
            border-radius: 6px;
            transition: all 0.2s ease;
            z-index: 2;
            line-height: 1;
        }

        .password-wrapper .toggle-pwd:hover {
            color: #FF7F11;
            background: rgba(255,127,17,0.08);
        }

        .auth-card .text-danger,
        .auth-card .field-validation-error {
            font-size: 12px;
            margin-top: 4px;
            display: block;
            color: #EF4444;
            padding-left: 2px;
        }

        .auth-card .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .auth-card .validation-summary-errors li {
            font-size: 12px;
            color: #EF4444;
            padding: 2px 0;
        }

        .auth-card .alert {
            font-size: 13px;
            padding: 10px 14px;
            border-radius: 10px;
        }

        .auth-card .btn-primary {
            padding: 12px;
            font-size: 14px;
            font-weight: 600;
            border-radius: 10px;
            background: #FF7F11;
            border: none;
            transition: all 0.3s ease;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            position: relative;
            overflow: hidden;
        }

        .auth-card .btn-primary::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 50%);
            pointer-events: none;
        }

        .auth-card .btn-primary:hover {
            background: #CC6600;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(255,127,17,0.35);
        }

        .auth-card .btn-primary:active {
            transform: translateY(0);
            box-shadow: 0 2px 8px rgba(255,127,17,0.25);
        }

        .auth-card .btn-primary:focus-visible {
            outline: 2px solid #FF7F11;
            outline-offset: 2px;
        }

        .auth-footer {
            text-align: center;
            margin-top: 22px;
            font-size: 13px;
            color: #9CA3AF;
        }

        .auth-footer a {
            color: #FF7F11;
            font-weight: 600;
            text-decoration: none;
            position: relative;
            transition: color 0.2s ease;
        }

        .auth-footer a::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 0;
            height: 1.5px;
            background: #FF7F11;
            transition: width 0.3s ease;
        }

        .auth-footer a:hover {
            color: #e8720f;
        }

        .auth-footer a:hover::after {
            width: 100%;
        }

        .auth-card .form-group {
            margin-bottom: 18px;
        }

        /* ─── Password Strength ─── */
        .password-strength-bar {
            height: 4px;
            background: #E5E7EB;
            border-radius: 4px;
            margin-top: 8px;
            overflow: hidden;
        }

        .password-strength-bar .strength-fill {
            height: 100%;
            width: 0;
            border-radius: 4px;
            transition: width 0.3s ease, background 0.3s ease;
        }

        .password-strength-text {
            font-size: 11px;
            font-weight: 500;
            color: #9CA3AF;
            margin-top: 4px;
            display: block;
            min-height: 16px;
            transition: color 0.3s ease;
        }

        /* ─── Responsive ─── */
        @@media (max-width: 480px) {
            .auth-card {
                padding: 28px 24px;
                max-width: 100%;
                border-radius: 12px;
                margin: 16px;
            }

            .auth-logo h2 {
                font-size: 16px;
            }

            .auth-card .form-control {
                padding: 11px 12px 11px 38px;
                font-size: 13px;
            }

            .input-icon-group .input-icon {
                left: 12px;
                font-size: 14px;
            }

            .auth-card .btn-primary {
                padding: 11px;
                font-size: 13px;
            }
        }

        @@media (min-width: 481px) and (max-width: 768px) {
            .auth-card {
                max-width: 400px;
                padding: 36px 32px;
            }
        }
    </style>
</head>
<body class="auth-page" aria-label="Authentication">
    @RenderBody()
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            // ─── Password Toggle ───
            document.querySelectorAll('.toggle-pwd').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var input = this.closest('.password-wrapper').querySelector('input');
                    var isPassword = input.type === 'password';
                    input.type = isPassword ? 'text' : 'password';
                    this.innerHTML = isPassword
                        ? '<i class="bi bi-eye-slash"></i>'
                        : '<i class="bi bi-eye"></i>';
                    this.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
                });
            });

            // ─── Password Strength (Register page) ───
            var pwdInput = document.getElementById('Password');
            var strengthFill = document.getElementById('strengthFill');
            var strengthText = document.getElementById('strengthText');

            if (pwdInput && strengthFill && strengthText) {
                pwdInput.addEventListener('input', function () {
                    var val = this.value;
                    var score = 0;
                    if (val.length >= 8) score++;
                    if (/[A-Z]/.test(val)) score++;
                    if (/[0-9]/.test(val)) score++;
                    if (/[^A-Za-z0-9]/.test(val)) score++;

                    var pct = (score / 4) * 100;
                    var color, label;
                    if (val.length === 0) {
                        pct = 0;
                        color = '#E5E7EB';
                        label = '';
                    } else if (score <= 1) {
                        color = '#EF4444';
                        label = 'Weak';
                    } else if (score === 2) {
                        color = '#F59E0B';
                        label = 'Medium';
                    } else {
                        color = '#10B981';
                        label = 'Strong';
                    }

                    strengthFill.style.width = pct + '%';
                    strengthFill.style.background = color;
                    strengthText.textContent = label;
                    strengthText.style.color = val.length === 0 ? '#9CA3AF' : color;
                });
            }

            // ─── Confirm Password Matching ───
            var confirmInput = document.getElementById('ConfirmPassword');
            var matchMsg = document.getElementById('passwordMatchMsg');

            if (pwdInput && confirmInput && matchMsg) {
                function checkMatch() {
                    if (confirmInput.value.length === 0) {
                        matchMsg.textContent = '';
                        return;
                    }
                    if (pwdInput.value === confirmInput.value) {
                        matchMsg.textContent = 'Passwords match';
                        matchMsg.style.color = '#10B981';
                    } else {
                        matchMsg.textContent = 'Passwords do not match';
                        matchMsg.style.color = '#EF4444';
                    }
                }
                pwdInput.addEventListener('input', checkMatch);
                confirmInput.addEventListener('input', checkMatch);
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
