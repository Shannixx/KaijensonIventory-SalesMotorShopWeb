@{
    string controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    bool IsActive(string c, string a = "") =>
        string.Equals(controller, c, StringComparison.OrdinalIgnoreCase) &&
        (string.IsNullOrEmpty(a) || string.Equals(action, a, StringComparison.OrdinalIgnoreCase));

    string? staffName = Context.Session.GetString("StaffName");
    string? staffRole = Context.Session.GetString("StaffRole");
    string avatarChar = !string.IsNullOrEmpty(staffName) ? staffName[..1].ToUpper() : "K";
    bool isAdmin = string.Equals(staffRole, "Admin", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kaijenson Motor Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KaijensonIventory_SalesMotorShopWeb.styles.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a asp-controller="Dashboard" asp-action="Index" class="sidebar-brand">
                <i class="bi bi-wrench"></i>
                <span class="brand-text">Kaijenson<br /><small>Motor Shop</small></span>
            </a>
            <button class="sidebar-close d-lg-none" id="sidebarClose">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="sidebar-body">
            <nav class="sidebar-nav">
                <ul class="nav-list">
                    <li class="nav-item">
                        <a asp-controller="Dashboard" asp-action="Index" class="nav-link @(IsActive("Dashboard") ? "active" : "")" data-title="Dashboard">
                            <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
                        </a>
                    </li>
                </ul>

                <div class="nav-section">Management</div>
                <ul class="nav-list">
                    <li class="nav-item">
                        <a asp-controller="Customers" asp-action="Index" class="nav-link @(IsActive("Customers") ? "active" : "")" data-title="Customers">
                            <i class="bi bi-people"></i><span>Customers</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Mechanics" asp-action="Index" class="nav-link @(IsActive("Mechanics") ? "active" : "")" data-title="Mechanic">
                            <i class="bi bi-tools"></i><span>Mechanic</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Suppliers" asp-action="Index" class="nav-link @(IsActive("Suppliers") ? "active" : "")" data-title="Supplier">
                            <i class="bi bi-truck"></i><span>Supplier</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Sales" asp-action="Index" class="nav-link @(IsActive("Sales") ? "active" : "")" data-title="Sales Transaction">
                            <i class="bi bi-cash-coin"></i><span>Sales Transaction</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Products" asp-action="Index" class="nav-link @(IsActive("Products") ? "active" : "")" data-title="Product">
                            <i class="bi bi-box-seam-fill"></i><span>Product</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Services" asp-action="Index" class="nav-link @(IsActive("Services") ? "active" : "")" data-title="Service">
                            <i class="bi bi-gear"></i><span>Service</span>
                        </a>
                    </li>
                    @if (isAdmin)
                    {
                        <li class="nav-item">
                            <a asp-controller="Staff" asp-action="Index" class="nav-link @(IsActive("Staff") ? "active" : "")" data-title="Staff">
                                <i class="bi bi-people-fill"></i><span>Staff</span>
                            </a>
                        </li>
                    }
                </ul>

                <div class="nav-section">System</div>
                <ul class="nav-list">
                    <li class="nav-item">
                        <a asp-controller="ActivityLog" asp-action="Index" class="nav-link @(IsActive("ActivityLog") ? "active" : "")" data-title="Activity Log">
                            <i class="bi bi-clock-history"></i><span>Activity Log</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Notifications" asp-action="Index" class="nav-link @(IsActive("Notifications") ? "active" : "")" data-title="Notifications">
                            <i class="bi bi-bell-fill"></i><span>Notifications</span>
                        </a>
                    </li>
                    @if (isAdmin)
                    {
                        <li class="nav-item">
                            <a asp-controller="Staff" asp-action="Index" class="nav-link @(IsActive("Staff") && action == "Index" ? "active" : "")" data-title="Access Control">
                                <i class="bi bi-shield-lock-fill"></i><span>Access Control</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Backups" asp-action="Index" class="nav-link @(IsActive("Backups") ? "active" : "")" data-title="Backup &amp; Recovery">
                                <i class="bi bi-hdd-stack-fill"></i><span>Backup &amp; Recovery</span>
                            </a>
                        </li>
                    }
                </ul>

                <div class="nav-section">Inventory &amp; Reports</div>
                <ul class="nav-list">
                    <li class="nav-item">
                        <a asp-controller="PurchaseOrders" asp-action="Index" class="nav-link @(IsActive("PurchaseOrders") ? "active" : "")" data-title="Purchase Orders">
                            <i class="bi bi-file-earmark-text"></i><span>Purchase Orders</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="StockIns" asp-action="Index" class="nav-link @(IsActive("StockIns") ? "active" : "")" data-title="Stock In">
                            <i class="bi bi-box-arrow-in-right"></i><span>Stock In</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="InventoryHistory" asp-action="Index" class="nav-link @(IsActive("InventoryHistory") ? "active" : "")" data-title="Inventory History">
                            <i class="bi bi-clock-history"></i><span>Inventory History</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Reports" asp-action="Index" class="nav-link @(IsActive("Reports") ? "active" : "")" data-title="Reports">
                            <i class="bi bi-file-earmark-bar-graph"></i><span>Reports</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
        <div class="sidebar-footer">
            <a asp-controller="Account" asp-action="Logout" class="nav-link logout-link" data-title="Log Out"><i class="bi bi-box-arrow-right"></i><span>Log Out</span></a>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="main-wrapper">
        <header class="top-header">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sidebar" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="bi bi-list"></i>
                </button>
                <div class="search-box d-none d-md-flex">
                    <i class="bi bi-search"></i>
                    <input type="text" class="form-control" placeholder="Search products..." id="globalSearch" />
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <a asp-controller="Notifications" asp-action="Index" class="btn-icon position-relative" title="Notifications">
                    <i class="bi bi-bell-fill"></i>
                    <span class="notif-dot" id="notifDot"></span>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notifBadge" style="font-size:9px; display:none;">0</span>
                </a>
                <div class="dropdown">
                    <button class="btn dropdown-toggle d-flex align-items-center gap-2 bg-transparent border-0" data-bs-toggle="dropdown">
                        <div class="avatar-sm" style="background: rgba(253,126,20,0.15); color: var(--primary); font-weight: 600;">@avatarChar</div>
                        <div class="d-none d-md-block text-start">
                            <div class="small fw-medium" style="line-height:1.2">@(staffName ?? "User")</div>
                            <div class="small" style="font-size:11px; color: var(--text-muted);">@(staffRole ?? "")</div>
                        </div>
                        <i class="bi bi-chevron-down" style="font-size:12px; color: var(--text-muted);"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="min-width:200px;">
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Sign Out</a></li>
                    </ul>
                </div>
            </div>
        </header>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
