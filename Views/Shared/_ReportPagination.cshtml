@{
    int page = (int)(ViewData["Page"] ?? 1);
    int totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var excludeKeys = new[] { "page" };
    var qs = string.Join("&", Context.Request.Query
        .Where(q => !excludeKeys.Contains(q.Key))
        .SelectMany(q => q.Value.Select(v => $"{q.Key}={Uri.EscapeDataString(v ?? "")}")));
}

@if (totalPages > 1)
{
    <nav class="report-pagination mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" href="?page=@(page - 1)&@qs">
                    <i class="bi bi-chevron-left"></i> Previous
                </a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" href="?page=@i&@qs">@i</a>
                </li>
            }
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" href="?page=@(page + 1)&@qs">
                    Next <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}
