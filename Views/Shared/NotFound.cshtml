@{
    ViewData["Title"] = "Page Not Found";
    Layout = "_AuthLayout";
}

<div class="auth-card" style="text-align:center;">
    <div class="auth-logo">
        <div class="logo-icon"><i class="bi bi-question-circle"></i></div>
        <h2>404 - Page Not Found</h2>
        <p>The page you are looking for does not exist or has been moved.</p>
    </div>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary w-100"><i class="bi bi-house"></i> Go to Dashboard</a>
</div>
