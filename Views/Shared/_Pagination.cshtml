@{
    int page = (int)(ViewData["Page"] ?? 1);
    int totalPages = (int)(ViewData["TotalPages"] ?? 1);
    string? filter = ViewData["CurrentFilter"] as string;
    string query = !string.IsNullOrEmpty(filter) ? "&searchString=" + Uri.EscapeDataString(filter) : "";
}

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" href="?page=@(page - 1)@query">Previous</a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" href="?page=@i@query">@i</a>
                </li>
            }
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" href="?page=@(page + 1)@query">Next</a>
            </li>
        </ul>
    </nav>
}
