@model DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p>Welcome to Kaijenson Motor Shop.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon primary"><i class="bi bi-box-seam"></i></div>
            <div class="metric-info">
                <p class="metric-label">Total Products</p>
                <h3 class="metric-value" data-countup="@Model.TotalProducts">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon warning"><i class="bi bi-exclamation-triangle"></i></div>
            <div class="metric-info">
                <p class="metric-label">Low Stock Products</p>
                <h3 class="metric-value" data-countup="@Model.LowStockCount">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon danger"><i class="bi bi-x-octagon"></i></div>
            <div class="metric-info">
                <p class="metric-label">Out of Stock</p>
                <h3 class="metric-value" data-countup="@Model.OutOfStockCount">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon primary"><i class="bi bi-people"></i></div>
            <div class="metric-info">
                <p class="metric-label">Total Customers</p>
                <h3 class="metric-value" data-countup="@Model.TotalCustomers">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon warning"><i class="bi bi-person-walk"></i></div>
            <div class="metric-info">
                <p class="metric-label">Walk-In Customers</p>
                <h3 class="metric-value" data-countup="@Model.WalkInCount">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon success"><i class="bi bi-person-check"></i></div>
            <div class="metric-info">
                <p class="metric-label">Registered Customers</p>
                <h3 class="metric-value" data-countup="@Model.RegisteredCustomers">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon danger"><i class="bi bi-arrow-repeat"></i></div>
            <div class="metric-info">
                <p class="metric-label">Need Reorder</p>
                <h3 class="metric-value" data-countup="@Model.LowStockRequireReorder">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon primary"><i class="bi bi-file-earmark-text"></i></div>
            <div class="metric-info">
                <p class="metric-label">Pending POs</p>
                <h3 class="metric-value" data-countup="@Model.PendingPurchaseOrders">0</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon success"><i class="bi bi-cash-coin"></i></div>
            <div class="metric-info">
                <p class="metric-label">Monthly Revenue</p>
                <h3 class="metric-value" data-countup="@Model.MonthlyRevenue" data-decimals="2" data-prefix="₱">₱0.00</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon info"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="metric-info">
                <p class="metric-label">Monthly Profit</p>
                <h3 class="metric-value" data-countup="@Model.MonthlyProfit" data-decimals="2" data-prefix="₱">₱0.00</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon info"><i class="bi bi-currency-dollar"></i></div>
            <div class="metric-info">
                <p class="metric-label">Inventory Value</p>
                <h3 class="metric-value" data-countup="@Model.TotalInventoryValue" data-decimals="2" data-prefix="₱">₱0.00</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon primary"><i class="bi bi-pie-chart"></i></div>
            <div class="metric-info">
                <p class="metric-label">Profit Margin</p>
                <h3 class="metric-value" data-countup="@Model.ProfitMargin" data-decimals="1" data-suffix="%">0%</h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">Revenue & Profit Trend</div>
            <div class="card-body">
                <canvas id="salesChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Products by Category</div>
            <div class="card-body">
                <canvas id="categoryChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Low Stock Alerts</div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table">
                        <thead><tr><th>Product</th><th>Qty</th><th>Reorder</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var p in Model.RecentLowStockProducts)
                            {
                                <tr>
                                    <td><a asp-controller="Products" asp-action="Details" asp-route-id="@p.ProductId">@p.ProductName</a></td>
                                    <td class="text-danger fw-semibold">@p.QuantityOnHand</td>
                                    <td>@p.ReorderLevel</td>
                                    <td>
                                        <a asp-controller="PurchaseOrders" asp-action="CreateFromLowStock" asp-route-productId="@p.ProductId" class="btn btn-sm btn-outline-primary" title="Generate PO"><i class="bi bi-file-earmark-plus"></i></a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.RecentLowStockProducts.Any())
                            {
                                <tr><td colspan="4" class="text-center py-4 text-muted">No low stock items.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            @if (Model.RecentLowStockProducts.Any())
            {
                <div class="card-footer text-center">
                    <a asp-controller="PurchaseOrders" asp-action="CreateFromLowStock" class="btn btn-sm btn-primary"><i class="bi bi-file-earmark-plus"></i> Generate Purchase Order</a>
                </div>
            }
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Recent Sales</div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table">
                        <thead><tr><th>Invoice</th><th>Customer</th><th>Total</th><th>Cashier</th></tr></thead>
                        <tbody>
                            @foreach (var s in Model.RecentSales)
                            {
                                <tr><td><a asp-controller="Sales" asp-action="Details" asp-route-id="@s.TransactionId">@s.InvoiceNumber</a></td><td>@s.CustomerName</td><td>@s.TotalAmount.ToString("N2")</td><td>@s.Staff?.StaffName</td></tr>
                            }
                            @if (!Model.RecentSales.Any())
                            {
                                <tr><td colspan="4" class="text-center py-4 text-muted">No recent sales.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Top Selling Products</div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table">
                        <thead><tr><th>Product</th><th>Qty Sold</th><th>Revenue</th></tr></thead>
                        <tbody>
                            @foreach (var tp in Model.TopSellingProducts)
                            {
                                <tr><td>@tp.ProductName</td><td>@tp.TotalQuantity</td><td>@tp.TotalRevenue.ToString("N2")</td></tr>
                            }
                            @if (!Model.TopSellingProducts.Any())
                            {
                                <tr><td colspan="3" class="text-center py-4 text-muted">No sales data yet.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-2">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">Recent Stock In</div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table">
                        <thead><tr><th>Date</th><th>Product</th><th>Qty</th><th>Supplier</th></tr></thead>
                        <tbody>
                            @foreach (var si in Model.RecentStockIns)
                            {
                                <tr>
                                    <td>@si.DeliveryDate.ToString("MMM dd")</td>
                                    <td>@si.Product?.ProductName</td>
                                    <td>@si.QuantityReceived</td>
                                    <td>@si.Supplier?.CompanyName</td>
                                </tr>
                            }
                            @if (!Model.RecentStockIns.Any())
                            {
                                <tr><td colspan="4" class="text-center py-4 text-muted">No stock in records.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">Top Customers</div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table">
                        <thead><tr><th>Customer</th><th>Lifetime Spend</th><th>Purchases</th></tr></thead>
                        <tbody>
                            @foreach (var c in Model.TopCustomers)
                            {
                                <tr>
                                    <td><a asp-controller="Customers" asp-action="Details" asp-route-id="@c.CustomerId" class="fw-medium">@c.CustomerName</a></td>
                                    <td>@c.TotalPurchases.ToString("N2")</td>
                                    <td>@c.TransactionCount</td>
                                </tr>
                            }
                            @if (!Model.TopCustomers.Any())
                            {
                                <tr><td colspan="3" class="text-center py-4 text-muted">No customer data yet.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">Active Alerts</div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table">
                        <thead><tr><th>Type</th><th>Message</th><th>Date</th></tr></thead>
                        <tbody>
                            @foreach (var n in Model.ActiveAlerts)
                            {
                                <tr>
                                    <td><span class="badge @(n.AlertType == "Stock Alert" ? "bg-danger" : "bg-warning text-dark")">@n.AlertType</span></td>
                                    <td class="small">@n.Message</td>
                                    <td class="small">@n.CreatedAt.ToString("MMM dd")</td>
                                </tr>
                            }
                            @if (!Model.ActiveAlerts.Any())
                            {
                                <tr><td colspan="3" class="text-center py-4 text-muted">No active alerts.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-2">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">Top Loyal Customers</div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table">
                        <thead><tr><th>Customer</th><th>Lifetime Spend</th><th>Reward Points</th><th>Tier</th><th>Transactions</th></tr></thead>
                        <tbody>
                            @foreach (var c in Model.TopLoyalCustomers)
                            {
                                string tier = c.TotalPurchases >= 50000 ? "Platinum" : c.TotalPurchases >= 20000 ? "Gold" : c.TotalPurchases >= 10000 ? "Silver" : c.TotalPurchases >= 3000 ? "Bronze" : "Regular";
                                string tierBadge = tier switch { "Platinum" => "bg-dark", "Gold" => "bg-warning text-dark", "Silver" => "bg-secondary", "Bronze" => "bg-danger", _ => "bg-light text-dark" };
                                <tr>
                                    <td><a asp-controller="Customers" asp-action="Details" asp-route-id="@c.CustomerId" class="fw-medium">@c.CustomerName</a></td>
                                    <td>@c.TotalPurchases.ToString("N2")</td>
                                    <td><span class="badge bg-warning text-dark">@c.RewardPoints</span></td>
                                    <td><span class="badge @tierBadge">@tier</span></td>
                                    <td>@c.TransactionCount</td>
                                </tr>
                            }
                            @if (!Model.TopLoyalCustomers.Any())
                            {
                                <tr><td colspan="5" class="text-center py-4 text-muted">No loyalty data yet.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-2">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">Ongoing Services</div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table">
                        <thead><tr><th>Customer</th><th>Vehicle</th><th>Status</th><th>Fee</th><th>Date</th></tr></thead>
                        <tbody>
                            @foreach (var sv in Model.OngoingServices)
                            {
                                <tr>
                                    <td>@sv.CustomerName</td>
                                    <td>@(sv.Make ?? "-") @(sv.Model ?? "")</td>
                                    <td>
                                        @{
                                            string badgeClass = sv.Status switch
                                            {
                                                "Pending" => "bg-warning",
                                                "In Progress" => "bg-info",
                                                "Completed" => "bg-success",
                                                "Cancelled" => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@sv.Status</span>
                                    </td>
                                    <td>@sv.ServiceFee.ToString("N2")</td>
                                    <td>@sv.Date.ToString("MMM dd")</td>
                                </tr>
                            }
                            @if (!Model.OngoingServices.Any())
                            {
                                <tr><td colspan="5" class="text-center py-4 text-muted">No ongoing services.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const salesCtx = document.getElementById('salesChart').getContext('2d');
        new Chart(salesCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.ChartLabels)),
                datasets: [
                    {
                        label: 'Revenue',
                        data: @Html.Raw(Json.Serialize(Model.ChartSalesData)),
                        backgroundColor: 'rgba(255,127,17,0.7)',
                        borderColor: 'rgba(255,127,17,1)',
                        borderWidth: 1
                    },
                    {
                        label: 'Profit',
                        data: @Html.Raw(Json.Serialize(Model.ChartProfitData)),
                        backgroundColor: 'rgba(16,185,129,0.7)',
                        borderColor: 'rgba(16,185,129,1)',
                        borderWidth: 1
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'top', labels: { font: { size: 11 } } } },
                scales: { y: { beginAtZero: true, ticks: { callback: v => '₱' + v.toLocaleString() } } }
            }
        });

        const catCtx = document.getElementById('categoryChart').getContext('2d');
        const catColors = ['rgba(255,127,17,0.8)', 'rgba(16,185,129,0.8)', 'rgba(59,130,246,0.8)', 'rgba(239,68,68,0.8)', 'rgba(245,158,11,0.8)', 'rgba(139,92,246,0.8)', 'rgba(236,72,153,0.8)'];
        new Chart(catCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.CategoryLabels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.CategoryCounts)),
                    backgroundColor: catColors.slice(0, @Model.CategoryLabels.Count),
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom', labels: { font: { size: 11 } } } }
            }
        });
    </script>
}
