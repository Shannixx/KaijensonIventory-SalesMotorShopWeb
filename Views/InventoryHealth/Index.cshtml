@model InventoryHealthViewModel
@{ ViewData["Title"] = "Inventory Health Check"; }

<div class="page-header">
    <div>
        <h1>Inventory Health Check</h1>
        <p>Validate product stock levels against transaction history.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#adjustmentModal"><i class="bi bi-pencil-square"></i> Manual Adjustment</button>
        <form asp-action="RebuildBalances" method="post" onsubmit="return confirm('This will create adjustment transactions to fix all discrepancies. Continue?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning"><i class="bi bi-arrow-repeat"></i> Rebuild Balances</button>
        </form>
    </div>
</div>

@if (TempData["SuccessMessage"] != null) { <div class="alert alert-success mb-3">@TempData["SuccessMessage"]</div> }
@if (TempData["ErrorMessage"] != null) { <div class="alert alert-danger mb-3">@TempData["ErrorMessage"]</div> }

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon primary"><i class="bi bi-box-seam"></i></div>
            <div class="metric-info">
                <p class="metric-label">Products Checked</p>
                <h3 class="metric-value">@Model.TotalChecked</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon @(Model.DiscrepancyCount > 0 ? "danger" : "success")"><i class="bi @(Model.DiscrepancyCount > 0 ? "bi-exclamation-triangle" : "bi-check-circle")"></i></div>
            <div class="metric-info">
                <p class="metric-label">Discrepancies</p>
                <h3 class="metric-value">@Model.DiscrepancyCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon info"><i class="bi bi-list-ul"></i></div>
            <div class="metric-info">
                <p class="metric-label">Total Transactions</p>
                <h3 class="metric-value">@Model.TotalTransactions</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon @(Model.DiscrepancyCount == 0 ? "success" : "warning")"><i class="bi bi-shield-check"></i></div>
            <div class="metric-info">
                <p class="metric-label">Status</p>
                <h3 class="metric-value small">
                    @if (Model.DiscrepancyCount == 0) { <span class="text-success">All OK</span> }
                    else { <span class="text-danger">Mismatch Found</span> }
                </h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">Transaction Type Summary</div>
            <div class="card-body">
                <div class="row text-center g-3">
                    <div class="col"><div class="small text-muted">Opening Balance</div><strong>@Model.OpeningBalanceCount</strong></div>
                    <div class="col"><div class="small text-muted">Stock In</div><strong>@Model.StockInCount</strong></div>
                    <div class="col"><div class="small text-muted">Sale</div><strong>@Model.SaleCount</strong></div>
                    <div class="col"><div class="small text-muted">Sale Reversal</div><strong>@Model.SaleReversalCount</strong></div>
                    <div class="col"><div class="small text-muted">Service Use</div><strong>@Model.ServiceUseCount</strong></div>
                    <div class="col"><div class="small text-muted">PO Receiving</div><strong>@Model.POReceivingCount</strong></div>
                    <div class="col"><div class="small text-muted">Adjustment</div><strong>@Model.AdjustmentCount</strong></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Current Stock</th>
                        <th>Calculated Stock</th>
                        <th>Difference</th>
                        <th>Transactions</th>
                        <th>Avg Cost</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Products)
                    {
                        <tr class="@(p.HasDiscrepancy ? "table-danger" : "")">
                            <td class="fw-medium">@p.ProductName</td>
                            <td>@p.CurrentStock</td>
                            <td>@p.CalculatedStock</td>
                            <td class="@(p.Difference != 0 ? "fw-bold" : "")">@(p.Difference > 0 ? "+" : "")@p.Difference</td>
                            <td>@p.TransactionCount</td>
                            <td>@p.AverageCost.ToString("N2")</td>
                            <td>
                                @if (p.HasDiscrepancy)
                                {
                                    <span class="badge bg-danger">Mismatch</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">OK</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Products.Any())
                    {
                        <tr><td colspan="7" class="text-center py-4 text-muted">No products found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="adjustmentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateAdjustment" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Manual Inventory Adjustment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Product</label>
                        <select name="productId" class="form-select" required>
                            <option value="">Select product...</option>
                            @foreach (var p in Model.Products)
                            {
                                <option value="@p.ProductId">@p.ProductName (Current: @p.CurrentStock)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Adjustment Quantity (positive to add, negative to subtract)</label>
                        <input type="number" name="adjustmentQuantity" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reason</label>
                        <input type="text" name="reason" class="form-control" required placeholder="e.g., Miscount, Damage, Return to Supplier" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Apply Adjustment</button>
                </div>
            </form>
        </div>
    </div>
</div>
