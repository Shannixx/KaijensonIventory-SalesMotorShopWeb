@model Customer
@{ ViewData["Title"] = "Delete Customer"; }

<div class="page-header"><div><h1>Delete Customer</h1><p>Are you sure?</p></div></div>

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <strong>Name:</strong> @Model.CustomerName
        </div>
        <div class="mb-3">
            <strong>Contact:</strong> @(Model.ContactNumber ?? "-")
        </div>
        <div class="mb-3">
            <strong>Email:</strong> @(Model.Email ?? "-")
        </div>
        <div class="mb-3">
            <strong>Total Purchases:</strong> @Model.TotalPurchases.ToString("N2")
        </div>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="CustomerId" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
