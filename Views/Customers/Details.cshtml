@model Customer
@{
    ViewData["Title"] = Model.CustomerName;
    var recentSales = ViewBag.RecentSales as List<SalesTransaction> ?? new();
    var recentServices = ViewBag.RecentServices as List<ServiceTransaction> ?? new();
}

<div class="page-header">
    <div>
        <h1>@Model.CustomerName</h1>
        <p>Customer details and history.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="small text-muted">Contact Number</div>
                <div class="fw-medium">@(Model.ContactNumber ?? "-")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="small text-muted">Email</div>
                <div class="fw-medium">@(Model.Email ?? "-")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="small text-muted">Total Purchases</div>
                <div class="fw-medium">@Model.TotalPurchases.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="small text-muted">Last Purchase</div>
                <div class="fw-medium">@(Model.LastPurchaseDate?.ToString("MMM dd, yyyy") ?? "N/A")</div>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <div class="small text-muted">Address</div>
                <div class="fw-medium">@(Model.Address ?? "-")</div>
            </div>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.Notes))
    {
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="small text-muted">Notes</div>
                    <div>@Model.Notes</div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><span>Recent Sales</span></div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Invoice</th>
                                <th>Date</th>
                                <th>Total</th>
                                <th>Cashier</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sale in recentSales)
                            {
                                <tr>
                                    <td><a asp-controller="Sales" asp-action="Details" asp-route-id="@sale.TransactionId">@sale.InvoiceNumber</a></td>
                                    <td>@sale.TransactionDate.ToString("MMM dd, yyyy")</td>
                                    <td>@sale.TotalAmount.ToString("N2")</td>
                                    <td>@sale.Staff?.StaffName</td>
                                </tr>
                            }
                            @if (!recentSales.Any())
                            {
                                <tr><td colspan="4" class="text-center py-3 text-muted">No sales yet.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><span>Recent Services</span></div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Fee</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var svc in recentServices)
                            {
                                <tr>
                                    <td><a asp-controller="ServiceTransactions" asp-action="Details" asp-route-id="@svc.ServiceTxnId">#@svc.ServiceTxnId</a></td>
                                    <td>@svc.Date.ToString("MMM dd, yyyy")</td>
                                    <td>@svc.Status</td>
                                    <td>@svc.ServiceFee.ToString("N2")</td>
                                </tr>
                            }
                            @if (!recentServices.Any())
                            {
                                <tr><td colspan="4" class="text-center py-3 text-muted">No services yet.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
