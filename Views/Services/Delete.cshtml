@model Service
@{ ViewData["Title"] = "Delete Service"; }
<div class="page-header">
    <div>
        <h1>Delete Service</h1>
        <p>Are you sure you want to delete this service?</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Back to List</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card">
    <div class="card-body">
        <dl class="row mb-4">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.ServiceId</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.ServiceName</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Model.ServicePrice.ToString("N2")</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category?.CategoryName</dd>

            <dt class="col-sm-3">Mechanic</dt>
            <dd class="col-sm-9">@Model.Mechanic?.MechanicName</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="ServiceId" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
            <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
        </form>
    </div>
</div>
