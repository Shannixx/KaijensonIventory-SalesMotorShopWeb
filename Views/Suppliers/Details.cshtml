@model KaijensonIventory_SalesMotorShopWeb.Models.Supplier
@{
    ViewData["Title"] = Model.CompanyName;
    var recentDeliveries = ViewBag.RecentDeliveries as List<StockIn> ?? new();
    var recentPOs = ViewBag.RecentPurchaseOrders as List<PurchaseOrder> ?? new();
}

<div class="page-header">
    <div>
        <h1>@Model.CompanyName</h1>
        <p>Supplier details, products, deliveries, and purchase orders.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.SupplierId" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon primary"><i class="bi bi-box-seam"></i></div>
            <div class="metric-info">
                <p class="metric-label">Products Supplied</p>
                <h3 class="metric-value">@ViewBag.TotalProducts</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon info"><i class="bi bi-truck"></i></div>
            <div class="metric-info">
                <p class="metric-label">Total Deliveries</p>
                <h3 class="metric-value">@ViewBag.StockInCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon success"><i class="bi bi-boxes"></i></div>
            <div class="metric-info">
                <p class="metric-label">Total Stock Supplied</p>
                <h3 class="metric-value">@ViewBag.TotalStockSupplied</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-icon warning"><i class="bi bi-cash-stack"></i></div>
            <div class="metric-info">
                <p class="metric-label">Total Value Supplied</p>
                <h3 class="metric-value small">₱@ViewBag.TotalValueSupplied.ToString("N2")</h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="metric-card">
            <div class="metric-icon info"><i class="bi bi-file-earmark-text"></i></div>
            <div class="metric-info">
                <p class="metric-label">Purchase Orders</p>
                <h3 class="metric-value">@ViewBag.PurchaseOrderCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card">
            <div class="metric-icon warning"><i class="bi bi-clock"></i></div>
            <div class="metric-info">
                <p class="metric-label">Pending POs</p>
                <h3 class="metric-value">@ViewBag.PendingPOCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card">
            <div class="metric-icon warning"><i class="bi bi-calendar-check"></i></div>
            <div class="metric-info">
                <p class="metric-label">Last Delivery</p>
                <h3 class="metric-value small">@(ViewBag.LastDeliveryDate?.ToString("MMM dd, yyyy") ?? "N/A")</h3>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.SupplierId)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.SupplierId)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.CompanyName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.CompanyName)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ContactPerson)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.ContactPerson)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ContactNumber)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.ContactNumber)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Address)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Address)</dd>
        </dl>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Products Supplied</span>
                <a asp-controller="Products" asp-action="Index" asp-route-searchString="@Model.CompanyName" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table mb-0">
                        <thead><tr><th>Product</th><th>Stock</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var p in Model.Products.Take(10))
                            {
                                <tr>
                                    <td><a asp-controller="Products" asp-action="Details" asp-route-id="@p.ProductId">@p.ProductName</a></td>
                                    <td>@p.QuantityOnHand</td>
                                    <td>
                                        @if (p.StockStatus == "Out of Stock") { <span class="badge bg-danger">Out of Stock</span> }
                                        else if (p.StockStatus == "Low Stock") { <span class="badge bg-warning text-dark">Low Stock</span> }
                                        else { <span class="badge bg-success">Available</span> }
                                    </td>
                                </tr>
                            }
                            @if (!Model.Products.Any())
                            {
                                <tr><td colspan="3" class="text-center py-3 text-muted">No products supplied.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <span>Recent Deliveries (Stock In)</span>
            </div>
            <div class="card-body p-0">
                <div class="table-container">
                    <table class="table mb-0">
                        <thead><tr><th>Date</th><th>Product</th><th>Qty</th><th>Cost</th><th>Staff</th></tr></thead>
                        <tbody>
                            @foreach (var si in recentDeliveries)
                            {
                                <tr>
                                    <td>@si.DeliveryDate.ToString("MMM dd, yyyy")</td>
                                    <td>@si.Product?.ProductName</td>
                                    <td>@si.QuantityReceived</td>
                                    <td>@si.UnitCost.ToString("N2")</td>
                                    <td>@si.Staff?.StaffName</td>
                                </tr>
                            }
                            @if (!recentDeliveries.Any())
                            {
                                <tr><td colspan="5" class="text-center py-3 text-muted">No deliveries yet.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@if (recentPOs.Any())
{
    <div class="card mt-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Purchase Orders</span>
            <a asp-controller="PurchaseOrders" asp-action="Index" asp-route-searchString="@Model.CompanyName" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
        <div class="card-body p-0">
            <div class="table-container">
                <table class="table mb-0">
                    <thead><tr><th>PO #</th><th>Date</th><th>Total</th><th>Status</th><th>Created By</th></tr></thead>
                    <tbody>
                        @foreach (var po in recentPOs)
                        {
                            <tr>
                                <td><a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@po.PurchaseOrderId">@po.PONumber</a></td>
                                <td>@po.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>@po.TotalAmount.ToString("N2")</td>
                                <td>
                                    @{ string poBadge = po.Status switch { "Draft" => "bg-secondary", "Ordered" => "bg-primary", "Partially Received" => "bg-info", "Received" => "bg-success", "Cancelled" => "bg-danger", _ => "bg-secondary" }; }
                                    <span class="badge @poBadge">@po.Status</span>
                                </td>
                                <td>@po.Staff?.StaffName</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
