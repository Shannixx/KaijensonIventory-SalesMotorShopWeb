@model IEnumerable<Product>
@{ ViewData["Title"] = "Inventory Summary"; }

<div class="page-header">
    <div>
        <h1>Inventory Summary</h1>
        <p>Product inventory report.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="ExportInventorySummary" class="report-btn report-btn-outline" id="exportBtn"
           data-params="@(Context.Request.QueryString.Value)">
            <i class="bi bi-file-earmark-excel"></i> Excel
        </a>
        <a asp-action="PdfInventorySummary" class="report-btn report-btn-outline"
           data-params="@(Context.Request.QueryString.Value)">
            <i class="bi bi-filetype-pdf"></i> PDF
        </a>
        <a asp-action="Index" class="report-btn report-btn-outline">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

@* Stats *@
@if (ViewBag.Stats is ReportStatsViewModel s)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="report-stat-card">
                <div class="report-stat-icon sales"><i class="bi bi-receipt"></i></div>
                <div class="report-stat-info">
                    <div class="report-stat-label">Total Sales</div>
                    <div class="report-stat-value" data-countup="@s.TotalSales" data-duration="1000">0</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="report-stat-card">
                <div class="report-stat-icon inventory"><i class="bi bi-boxes"></i></div>
                <div class="report-stat-info">
                    <div class="report-stat-label">Filtered Products</div>
                    <div class="report-stat-value" data-countup="@s.TotalInventory" data-duration="1000">0</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="report-stat-card">
                <div class="report-stat-icon service"><i class="bi bi-tools"></i></div>
                <div class="report-stat-info">
                    <div class="report-stat-label">Service Txns</div>
                    <div class="report-stat-value" data-countup="@s.TotalServices" data-duration="1000">0</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="report-stat-card">
                <div class="report-stat-icon activity"><i class="bi bi-clock-history"></i></div>
                <div class="report-stat-info">
                    <div class="report-stat-label">Activity Logs</div>
                    <div class="report-stat-value" data-countup="@s.TotalActivities" data-duration="1000">0</div>
                </div>
            </div>
        </div>
    </div>
}

@* Filters *@
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Category</label>
                <select name="categoryId" class="form-select form-select-sm" asp-items="ViewBag.Categories">
                    <option value="">All Categories</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input type="text" name="search" class="form-control form-control-sm" placeholder="Product name..." value="@ViewData["Search"]" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="report-btn flex-fill"><i class="bi bi-funnel"></i> Filter</button>
                <a asp-action="InventorySummary" class="report-btn report-btn-outline flex-fill"><i class="bi bi-x-circle"></i> Clear</a>
            </div>
        </form>
    </div>
</div>

@* Table *@
<div class="card">
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Supplier</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="fw-medium">@item.ProductName</span></td>
                            <td>@item.Category?.CategoryName</td>
                            <td>@item.Supplier?.CompanyName</td>
                            <td class="fw-semibold">@item.Price.ToString("N2")</td>
                            <td>@item.QuantityOnHand</td>
                            <td>
                                @{
                                    string badgeClass = item.StockStatus switch
                                    {
                                        "Available" => "bg-success",
                                        "Low Stock" => "bg-warning",
                                        "Out of Stock" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@item.StockStatus</span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center py-4 text-muted">No products found matching your filters.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<partial name="_ReportPagination" />
