@model IEnumerable<ActivityLog>
@{ ViewData["Title"] = "Activity Summary"; }

<div class="page-header">
    <div>
        <h1>Activity Summary</h1>
        <p>System audit trail report.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="ExportActivitySummary" class="report-btn report-btn-outline" id="exportBtn"
           data-params="@(Context.Request.QueryString.Value)">
            <i class="bi bi-file-earmark-excel"></i> Export Excel
        </a>
        <a asp-action="Index" class="report-btn report-btn-outline">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

@* Stats *@
@if (ViewBag.Stats is ReportStatsViewModel s)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="report-stat-card">
                <div class="report-stat-icon sales"><i class="bi bi-receipt"></i></div>
                <div class="report-stat-info">
                    <div class="report-stat-label">Total Sales</div>
                    <div class="report-stat-value" data-countup="@s.TotalSales" data-duration="1000">0</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="report-stat-card">
                <div class="report-stat-icon inventory"><i class="bi bi-boxes"></i></div>
                <div class="report-stat-info">
                    <div class="report-stat-label">Products</div>
                    <div class="report-stat-value" data-countup="@s.TotalInventory" data-duration="1000">0</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="report-stat-card">
                <div class="report-stat-icon service"><i class="bi bi-tools"></i></div>
                <div class="report-stat-info">
                    <div class="report-stat-label">Service Txns</div>
                    <div class="report-stat-value" data-countup="@s.TotalServices" data-duration="1000">0</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="report-stat-card">
                <div class="report-stat-icon activity"><i class="bi bi-clock-history"></i></div>
                <div class="report-stat-info">
                    <div class="report-stat-label">Filtered Activities</div>
                    <div class="report-stat-value" data-countup="@s.TotalActivities" data-duration="1000">0</div>
                </div>
            </div>
        </div>
    </div>
}

@* Filters *@
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Date From</label>
                <input type="date" name="dateFrom" class="form-control form-control-sm" value="@ViewData["DateFrom"]" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Date To</label>
                <input type="date" name="dateTo" class="form-control form-control-sm" value="@ViewData["DateTo"]" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Module</label>
                <select name="module" class="form-select form-select-sm" asp-items="ViewBag.Modules">
                    <option value="">All Modules</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Search</label>
                <input type="text" name="search" class="form-control form-control-sm" placeholder="Action / Module..." value="@ViewData["Search"]" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="report-btn flex-fill"><i class="bi bi-funnel"></i> Filter</button>
                <a asp-action="ActivitySummary" class="report-btn report-btn-outline flex-fill"><i class="bi bi-x-circle"></i> Clear</a>
            </div>
        </form>
    </div>
</div>

@* Table *@
<div class="card">
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>Module</th>
                        <th>Action</th>
                        <th>Staff</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="text-nowrap">@item.Timestamp.ToString("MMM dd, yyyy HH:mm")</span></td>
                            <td><span class="badge bg-info">@item.Module</span></td>
                            <td>@item.Action</td>
                            <td>@item.Staff?.StaffName</td>
                            <td class="text-secondary" style="max-width:300px;">@item.Description</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center py-4 text-muted">No activities found matching your filters.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<partial name="_ReportPagination" />
